  "description": "A robust CLI bot that extracts contacts from WhatsApp groups and exports them as CSV/JSON using the Baileys library.",
  "author": "Cristiano Galdino",
  "license": "MIT",
  "type": "module",
  "main": "src/index.js",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
    "lint": "eslint src/ --ext .js",
    "lint:fix": "eslint src/ --ext .js --fix"
  },
  "dependencies": {
    "@whiskeysockets/baileys": "^6.7.9",
    "csv-writer": "^1.6.0",
    "dotenv": "^16.4.5",
