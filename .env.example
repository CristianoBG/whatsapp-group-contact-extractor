# ── WhatsApp Group Contact Extractor ──────────────────────────────────────────
# Copy this file to .env and adjust as needed.

# Logging level: trace | debug | info | warn | error | fatal
LOG_LEVEL=info

# Default export format: csv | json | both
EXPORT_FORMAT=csv

# Max number of participants processed concurrently from a single group
# Minimum: 1, Maximum: 20 (recommended: 5)
CONCURRENCY_LIMIT=5

# Optional: filter for group names (substring, case-insensitive)
# Example: "Friends" will only show groups with "Friends" in the name.
GROUP_FILTER=

# ── Path Configuration ────────────────────────────────────────────────────────
# Relative to project root
SESSION_DIR=./session
OUTPUT_DIR=./output

# ── Internal (do not change) ──────────────────────────────────────────────────
NODE_ENV=production
RUNNING_IN_DOCKER=false
